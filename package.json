    "test:watch": "vitest",
    "release": "node scripts/bump-version.mjs --tag"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonherrmann/wdh-widgets-core.git"
  },
  "license": "MIT",
  "dependencies": {
    "lit": "^3.3.0"
  },
  "devDependencies": {
    "typescript": "~5.6.3",
    "vitest": "^2.1.9"
  }
}
